// @ts-nocheck
import { describe, it, expect, vi, beforeEach, afterEach } from 'vitest'
import { AgentOrchestrator } from './orchestrator'
import { LLMEngine } from './llm'
import { PythonRuntime } from './python-runtime'
import { storage } from './storage'
import { TOOLS } from './tools'
import 'fake-indexeddb/auto'

// Mock all external dependencies
vi.mock('./llm')
vi.mock('./python-runtime')
vi.mock('./tools', () => ({
  getSystemContext: vi.fn().mockResolvedValue('System context'),
  TOOLS: {}
}))

vi.mock('./skills/engine', () => ({
  skillsEngine: {
    init: vi.fn(),
    parseSkillCalls: vi.fn().mockReturnValue([]), // Return empty array by default
    executeSkill: vi.fn(),
    getSkillsDescription: vi.fn().mockReturnValue('Calculator: Perform mathematical calculations')
  }
}))
vi.mock('./storage', () => ({
  storage: {
    init: vi.fn(),
    getMemories: vi.fn().mockResolvedValue([]),
    addMemory: vi.fn(),
    clearMemories: vi.fn(),
    listFiles: vi.fn().mockResolvedValue([]),
    getFile: vi.fn(),
    saveFile: vi.fn(),
    deleteFile: vi.fn(),
    close: vi.fn()
  }
}))
vi.mock('./logger')

describe('Integration Tests', () => {
  let orchestrator: AgentOrchestrator
  let mockEngine: LLMEngine
  let mockPython: PythonRuntime
  let onUpdate: vi.MockedFunction<(response: any) => void>

  beforeEach(async () => {
    // Setup mocks
    mockEngine = {
      generate: vi.fn().mockImplementation(async (prompt, options) => {
        // Simulate the onToken callback being called
        if (options.onToken) {
          options.onToken('Task completed successfully. FINISH')
        }
        return {
          content: 'Task completed successfully. FINISH',
          usage: { prompt_tokens: 10, completion_tokens: 20 }
        }
      }),
      getStats: vi.fn()
    } as any

    mockPython = {
      onOutput: vi.fn(),
      execute: vi.fn(),
      initialized: false,
      init: vi.fn(),
      reset: vi.fn()
    } as any

    onUpdate = vi.fn()

    // Initialize storage
    await storage.init()

    // Create orchestrator
    orchestrator = new AgentOrchestrator(mockEngine, mockPython)
  })

  afterEach(() => {
    // close() doesn't exist, just let it be cleaned up
  })

  describe('End-to-End Task Execution', () => {
    it('should complete a simple task', async () => {
      // Execute task
      await orchestrator.runTask('Simple test task', onUpdate)

      // Verify task completion
      expect(onUpdate).toHaveBeenCalledWith({
        personaId: 'coder',
        content: 'Task completed successfully.',
        type: 'text'
      })
    })

    it('should handle task with memory', async () => {
      // Add initial memory
      vi.mocked(storage.addMemory).mockResolvedValue()
      vi.mocked(storage.getMemories).mockResolvedValue([{
        category: 'events',
        content: 'User prefers Python',
        tags: ['preference'],
        metadata: { source: 'user' },
        id: 1,
        timestamp: Date.now()
      }])

      // Mock LLM response
      vi.mocked(mockEngine.generate).mockImplementation(async (prompt, options) => {
        if (options.onToken) {
          options.onToken('Based on your preference for Python, here\'s a solution.')
        }
        return {
          content: 'Based on your preference for Python, here\'s a solution.',
          usage: { prompt_tokens: 40, completion_tokens: 25 }
        }
      })

      // Execute task
      await orchestrator.runTask('Create a solution', onUpdate)

      // Verify memory was used
      expect(mockEngine.generate).toHaveBeenCalledWith(
        expect.any(String),
        expect.objectContaining({
          history: expect.arrayContaining([
            expect.objectContaining({
              role: 'system',
              content: expect.stringContaining('User prefers Python')
            })
          ])
        })
      )
    })
  })

  describe('Error Handling', () => {
    it('should handle LLM errors gracefully', async () => {
      // Mock LLM error
      vi.mocked(mockEngine.generate).mockRejectedValue(new Error('LLM failed'))

      // Execute task
      await orchestrator.runTask('Test task', onUpdate)

      // Verify error handling
      expect(onUpdate).toHaveBeenCalledWith({
        personaId: 'system',
        content: expect.stringContaining('Error during task execution'),
        type: 'error'
      })
    })
  })

  describe('Tool Integration', () => {
    it('should have core tools defined', () => {
      expect(TOOLS).toHaveProperty('vfs_write')
      expect(TOOLS).toHaveProperty('vfs_read')
      expect(TOOLS).toHaveProperty('vfs_ls')
      expect(TOOLS).toHaveProperty('delegate')
    })

    it('should validate tool definitions', () => {
      Object.values(TOOLS).forEach(tool => {
        expect(tool).toHaveProperty('name')
        expect(tool).toHaveProperty('description')
        expect(tool).toHaveProperty('parameters')
      })
    })
  })

  describe('Memory Integration', () => {
    it('should add task completion memory', async () => {
      // Mock LLM response
      vi.mocked(mockEngine.generate).mockResolvedValueOnce({
        content: 'Task done.',
        usage: { prompt_tokens: 10, completion_tokens: 10 }
      })

      // Mock LLM response
      vi.mocked(mockEngine.generate).mockImplementation(async (prompt, options) => {
        if (options.onToken) {
          options.onToken('Task done.')
        }
        return {
          content: 'Task done.',
          usage: { prompt_tokens: 10, completion_tokens: 10 }
        }
      })

      // Execute task
      await orchestrator.runTask('Test task', onUpdate)

      // Verify memory was added
      expect(storage.addMemory).toHaveBeenCalledWith(
        'events',
        expect.stringContaining('Test task'),
        ['manager'],
        {}
      )
    })
  })
})
